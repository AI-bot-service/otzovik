# Project
PROJECT_NAME=otzovik
DOMAIN=otzovik.systemtool.ru
ENVIRONMENT=production

# Database
POSTGRES_USER=otzovik
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=otzovik
DATABASE_URL=postgresql+asyncpg://otzovik:CHANGE_ME_STRONG_PASSWORD@postgres:5432/otzovik

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=GENERATE_WITH_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS_ADMIN=30
REFRESH_TOKEN_EXPIRE_DAYS_USER=1

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=CHANGE_ME_APP_PASSWORD
SMTP_FROM=noreply@otzovik.systemtool.ru
SMTP_TLS=true

# Admin
ADMIN_EMAIL=russkihalex@gmail.com

# OpenAI API (for AI analysis)
OPENAI_API_KEY=CHANGE_ME_sk-xxxxx

# SearXNG (internal)
SEARXNG_URL=http://searxng:8080
SEARXNG_SECRET_KEY=GENERATE_WITH_openssl_rand_hex_32

# CORS
CORS_ORIGINS=["https://otzovik.systemtool.ru"]

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Search limits
MAX_SITES_PER_QUERY=20
MAX_QUERIES_PER_HOUR=5

# Stripe (будущая версия)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
